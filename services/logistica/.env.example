# Base de datos PostgreSQL
DB_NAME=modulo_logistica_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Entorno
NODE_ENV=production

# Puerto del servidor
PORT=3005

