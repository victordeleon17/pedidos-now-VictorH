{
  "info": {
    "name": "Restaurantes - Base",
    "_postman_id": "restaurantes-collection-001",
    "description": "Colección completa de endpoints para gestión de restaurantes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "restaurante_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Crear Restaurante Completo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/restaurantes",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Pizza Hut Centro\",\n  \"descripcion\": \"Las mejores pizzas de la ciudad\",\n  \"direccion\": \"Av. Principal 123\",\n  \"telefono\": \"555-1234\",\n  \"correo\": \"contacto@pizzahut.com\",\n  \"logo_url\": \"https://example.com/logo.png\",\n  \"disponible\": true\n}"
        }
      },
      "response": []
    },
    {
      "name": "02 - Crear Restaurante Mínimo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/restaurantes",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Restaurante Express\",\n  \"direccion\": \"Calle 123\",\n  \"telefono\": \"555-5555\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "03 - Listar Restaurantes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/restaurantes?activo=true&disponible=true",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes"],
          "query": [
            {
              "key": "activo",
              "value": "true"
            },
            {
              "key": "disponible",
              "value": "true"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "04 - Obtener Restaurante",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/restaurantes/{{restaurante_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes", "{{restaurante_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "05 - Actualizar Restaurante",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/restaurantes/{{restaurante_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes", "{{restaurante_id}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Pizza Hut Centro - Sucursal 1\",\n  \"telefono\": \"555-9999\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "06 - Eliminar (Inactivar) Restaurante",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/restaurantes/{{restaurante_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes", "{{restaurante_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "07 - Cambiar Disponibilidad",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/restaurantes/{{restaurante_id}}/disponibilidad",
          "host": ["{{baseUrl}}"],
          "path": ["restaurantes", "{{restaurante_id}}", "disponibilidad"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"disponible\": false\n}"
        }
      },
      "response": []
    }
  ]
}
