        {
          "listen": "test",
          "script": {
            "exec": [
              "// Guarda ids del response para usarlos en otros requests\r",
              "if (pm.response.code === 201 || pm.response.code === 200) {\r",
              "  const json = pm.response.json();\r",
              "\r",
              "  // según mi formato anterior: { ok: true, result: { payment_id, order_snapshot_id } }\r",
              "  const result = json.result || {};\r",
              "  const paymentId = result.payment_id || result.paymentId || result.id;\r",
              "  const orderSnapshotId = result.order_snapshot_id || result.orderSnapshotId;\r",
              "\r",
              "  if (paymentId) pm.environment.set(\"paymentId\", paymentId);\r",
              "  if (orderSnapshotId) pm.environment.set(\"orderSnapshotId\", orderSnapshotId);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
