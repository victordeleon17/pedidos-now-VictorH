    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get wallet summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {\r",
                  "  const json = pm.response.json();\r",
                  "  const txs = json.result?.transactions || json.transactions || [];\r",
                  "\r",
                  "  const pendingCash = txs.find(\r",
                  "    t => t.paymentMethod === \"CASH\" && t.isDebtSettled === false\r",
                  "  );\r",
                  "\r",
                  "  if (pendingCash) {\r",
                  "    if (pendingCash.transactionId) pm.collectionVariables.set(\"cashDebtTransactionId\", pendingCash.transactionId);\r",
                  "    if (pendingCash.orderId) pm.collectionVariables.set(\"cashDebtOrderId\", pendingCash.orderId);\r",
                  "  }\r",
                  "} catch (e) {}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/summary?courierId={{courierId}}&startDate=2026-03-01&endDate=2026-03-31",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "wallet",
                "summary"
              ],
              "query": [
                {
                  "key": "courierId",
                  "value": "{{courierId}}"
                },
                {
                  "key": "startDate",
                  "value": "2026-03-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-03-31"
                }
              ]
            }
          },
          "response": []
        },
