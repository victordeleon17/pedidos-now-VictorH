            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": \"11111111-1111-1111-1111-111111111111\",\n      \"product_name\": \"Hamburguesa\",\n      \"quantity\": 2,\n      \"unit_price\": 40,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    },\n    {\n      \"product_id\": \"22222222-2222-2222-2222-222222222222\",\n      \"product_name\": \"Papas\",\n      \"quantity\": 1,\n      \"unit_price\": 15,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    }\n  ],\n  \"product_discounts\": 0,\n  \"coupon_discount\": 0,\n  \"service_fee\": 5,\n  \"tip_amount\": 10,\n  \"weight_lbs\": 12,\n  \"insurance_value\": 0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "calculate"]
            }
          },
          "response": []
        },
        {
          "name": "Create payment - CARD_CREDIT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const result = json.result || {};",
                  "if (result.payment_id) pm.collectionVariables.set('paymentId', result.payment_id);",
                  "if (result.order_snapshot_id) pm.collectionVariables.set('orderSnapshotId', result.order_snapshot_id);",
                  "if (result.reservation_id) pm.collectionVariables.set('reservationId', result.reservation_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"courier_id\": \"{{courierId}}\",\n  \"business_id\": \"cccccccc-cccc-cccc-cccc-cccccccccccc\",\n  \"delivery_address_id\": \"dddddddd-dddd-dddd-dddd-dddddddddddd\",\n  \"reservation_id\": \"RES-CARD-{{timestamp}}\",\n  \"order_id\": \"ORD-CARD-{{timestamp}}\",\n  \"currency_code\": \"GTQ\",\n  \"payment_method_code\": \"CARD_CREDIT\",\n  \"card_type\": \"CREDIT\",\n  \"product_discounts\": 0,\n  \"coupon_discount\": 0,\n  \"service_fee\": 5,\n  \"courier_earned_fee\": 15,\n  \"approved_extra_fee\": 0,\n  \"tip_amount\": 10,\n  \"weight_lbs\": 12,\n  \"insurance_value\": 0,\n  \"items\": [\n    {\n      \"product_id\": \"11111111-1111-1111-1111-111111111111\",\n      \"external_product_id\": \"PROD-10\",\n      \"product_name\": \"Hamburguesa\",\n      \"quantity\": 2,\n      \"unit_price\": 40,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    },\n    {\n      \"product_id\": \"22222222-2222-2222-2222-222222222222\",\n      \"external_product_id\": \"PROD-11\",\n      \"product_name\": \"Papas\",\n      \"quantity\": 1,\n      \"unit_price\": 15,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    }\n  ],\n  \"idempotency_key\": \"idem-card-{{timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments"]
            }
          },
          "response": []
        },
        {
          "name": "Create payment - CASH",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const result = json.result || {};",
                  "if (result.payment_id) pm.collectionVariables.set('paymentId', result.payment_id);",
                  "if (result.order_snapshot_id) pm.collectionVariables.set('orderSnapshotId', result.order_snapshot_id);",
                  "if (result.reservation_id) pm.collectionVariables.set('reservationId', result.reservation_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"courier_id\": \"{{courierId}}\",\n  \"business_id\": \"cccccccc-cccc-cccc-cccc-cccccccccccc\",\n  \"delivery_address_id\": \"dddddddd-dddd-dddd-dddd-dddddddddddd\",\n  \"reservation_id\": \"RES-CASH-{{timestamp}}\",\n  \"order_id\": \"ORD-CASH-{{timestamp}}\",\n  \"currency_code\": \"GTQ\",\n  \"payment_method_code\": \"CASH\",\n  \"product_discounts\": 0,\n  \"coupon_discount\": 0,\n  \"service_fee\": 5,\n  \"courier_earned_fee\": 15,\n  \"approved_extra_fee\": 0,\n  \"tip_amount\": 10,\n  \"weight_lbs\": 12,\n  \"insurance_value\": 0,\n  \"items\": [\n    {\n      \"product_id\": \"11111111-1111-1111-1111-111111111111\",\n      \"external_product_id\": \"PROD-10\",\n      \"product_name\": \"Hamburguesa\",\n      \"quantity\": 2,\n      \"unit_price\": 40,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    }\n  ],\n  \"idempotency_key\": \"idem-cash-{{timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments"]
