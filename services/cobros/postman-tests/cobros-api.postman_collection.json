    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get wallet summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const txs = json.result?.transactions || [];",
                  "const pendingCash = txs.find(t => t.paymentMethod === 'CASH' && t.isDebtSettled === false);",
                  "if (pendingCash?.transactionId) pm.collectionVariables.set('cashDebtTransactionId', pendingCash.transactionId);",
                  "if (pendingCash?.orderId) pm.collectionVariables.set('cashDebtOrderId', pendingCash.orderId);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/summary?courierId={{courierId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "summary"],
              "query": [{ "key": "courierId", "value": "{{courierId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "Get wallet summary by date range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/summary?courierId={{courierId}}&startDate=2026-01-01&endDate=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "summary"],
              "query": [
                { "key": "courierId", "value": "{{courierId}}" },
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-12-31" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Pay pending by transactionId",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courierId\": \"{{courierId}}\",\n  \"transactionId\": \"{{cashDebtTransactionId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/wallet/pay-pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "pay-pending"]
            }
          },
          "response": []
        },
        {
          "name": "Pay pending by orderId",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courierId\": \"{{courierId}}\",\n  \"orderId\": \"{{cashDebtOrderId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/wallet/pay-pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "pay-pending"]
            }
          },
          "response": []
        }
      ]
    }
