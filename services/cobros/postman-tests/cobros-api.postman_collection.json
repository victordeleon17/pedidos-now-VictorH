    {
      "name": "01 - Restaurantes / Cobros",
      "description": "Endpoints principales para Restaurantes: calcular total, crear cobro, consultar cobros por orden/reserva/id, cancelar y reembolsar.",
      "item": [
        {
          "name": "POST /api/payments/calculate - calcular total antes de confirmar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('respuesta ok con totales', () => {",
                  "  pm.expect(json.ok).to.eql(true);",
                  "  pm.expect(json.result).to.include.keys('subtotal', 'total_discounts', 'service_fee', 'weight_fee', 'insurance_fee', 'priority_fee', 'tip_amount', 'total_amount');",
                  "});",
                  "pm.test('total esperado para payload ejemplo', () => {",
                  "  pm.expect(json.result.subtotal).to.eql(95);",
                  "  pm.expect(json.result.total_amount).to.eql(122);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Usar cuando Restaurante necesita previsualizar el total que Cobros calculara antes de crear el pago. Campos requeridos por item: product_id, product_name, quantity > 0, unit_price >= 0. Campos monetarios opcionales deben ser >= 0. No crea registros.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": \"{{productId1}}\",\n      \"product_name\": \"Hamburguesa\",\n      \"quantity\": 2,\n      \"unit_price\": 40,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    },\n    {\n      \"product_id\": \"{{productId2}}\",\n      \"product_name\": \"Papas\",\n      \"quantity\": 1,\n      \"unit_price\": 15,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    }\n  ],\n  \"product_discounts\": 0,\n  \"coupon_discount\": 0,\n  \"service_fee\": 5,\n  \"tip_amount\": 10,\n  \"weight_lbs\": 12,\n  \"insurance_value\": 0,\n  \"priority_shipping\": false,\n  \"apply_weather_surcharge\": false,\n  \"apply_traffic_surcharge\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "calculate"]
            }
          },
          "response": [
            {
              "name": "200 OK - totales calculados",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/payments/calculate"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"ok\": true,\n  \"result\": {\n    \"subtotal\": 95,\n    \"items_discount_total\": 0,\n    \"product_discounts\": 0,\n    \"coupon_discount\": 0,\n    \"total_discounts\": 0,\n    \"service_fee\": 5,\n    \"weight_lbs\": 12,\n    \"weight_fee\": 12,\n    \"weather_traffic_fee\": 0,\n    \"insurance_fee\": 0,\n    \"priority_fee\": 0,\n    \"tip_amount\": 10,\n    \"total_amount\": 122\n  }\n}"
            },
            {
              "name": "400 Bad Request - payload invalido",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"items\": []\n}" },
                "url": "{{baseUrl}}/api/payments/calculate"
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"ok\": false,\n  \"error\": \"items is required and must be a non-empty array\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/payments - crear cobro con tarjeta",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('cobro aprobado', () => {",
                  "  pm.expect(json.ok).to.eql(true);",
                  "  pm.expect(json.result.status).to.eql('APPROVED');",
                  "  pm.expect(json.result.settlement_status).to.eql('NOT_APPLICABLE');",
                  "  pm.expect(json.result.payment_id).to.be.a('string');",
                  "});",
                  "if (json.result?.payment_id) pm.collectionVariables.set('paymentId', json.result.payment_id);",
                  "if (json.result?.order_snapshot_id) pm.collectionVariables.set('orderSnapshotId', json.result.order_snapshot_id);",
                  "if (json.result?.reservation_id) pm.collectionVariables.set('reservationId', json.result.reservation_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Crea el cobro definitivo para una orden de Restaurante pagada con tarjeta. Requeridos: customer_id, courier_id, business_id, delivery_address_id, reservation_id, payment_method_code, idempotency_key e items validos. Para CARD_CREDIT/CARD_DEBIT tambien enviar card_type. Respuesta exitosa: 201 con payment_id, order_snapshot_id, reservation_id, status APPROVED, settlement_status y totals.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"courier_id\": \"{{courierId}}\",\n  \"business_id\": \"{{businessId}}\",\n  \"delivery_address_id\": \"{{deliveryAddressId}}\",\n  \"reservation_id\": \"RES-REST-{{timestamp}}\",\n  \"order_id\": \"ORD-REST-{{timestamp}}\",\n  \"currency_code\": \"GTQ\",\n  \"payment_method_code\": \"CARD_CREDIT\",\n  \"card_type\": \"CREDIT\",\n  \"product_discounts\": 0,\n  \"coupon_discount\": 0,\n  \"service_fee\": 5,\n  \"courier_earned_fee\": 15,\n  \"approved_extra_fee\": 0,\n  \"tip_amount\": 10,\n  \"weight_lbs\": 12,\n  \"insurance_value\": 0,\n  \"priority_shipping\": false,\n  \"apply_weather_surcharge\": false,\n  \"apply_traffic_surcharge\": false,\n  \"items\": [\n    {\n      \"product_id\": \"{{productId1}}\",\n      \"external_product_id\": \"REST-PROD-10\",\n      \"product_name\": \"Hamburguesa\",\n      \"quantity\": 2,\n      \"unit_price\": 40,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    },\n    {\n      \"product_id\": \"{{productId2}}\",\n      \"external_product_id\": \"REST-PROD-11\",\n      \"product_name\": \"Papas\",\n      \"quantity\": 1,\n      \"unit_price\": 15,\n      \"item_discount\": 0,\n      \"is_combo\": false\n    }\n  ],\n  \"idempotency_key\": \"rest-card-{{timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments"]
            }
          },
          "response": [
            {
              "name": "201 Created - cobro aprobado",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}" },
                "url": "{{baseUrl}}/api/payments"
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"ok\": true,\n  \"result\": {\n    \"payment_id\": \"uuid-del-pago\",\n    \"order_snapshot_id\": \"uuid-del-snapshot\",\n    \"reservation_id\": \"RES-REST-1710000000000\",\n    \"status\": \"APPROVED\",\n    \"settlement_status\": \"NOT_APPLICABLE\",\n    \"totals\": {\n      \"subtotal\": 95,\n      \"total_discounts\": 0,\n      \"service_fee\": 5,\n      \"weight_fee\": 12,\n      \"tip_amount\": 10,\n      \"total_amount\": 122\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /api/payments - crear cobro en efectivo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('cobro cash queda pendiente de liquidacion', () => {",
                  "  pm.expect(json.ok).to.eql(true);",
                  "  pm.expect(json.result.status).to.eql('APPROVED');",
                  "  pm.expect(json.result.settlement_status).to.eql('PENDING');",
                  "});",
                  "if (json.result?.payment_id) pm.collectionVariables.set('paymentId', json.result.payment_id);",
                  "if (json.result?.order_snapshot_id) pm.collectionVariables.set('orderSnapshotId', json.result.order_snapshot_id);",
                  "if (json.result?.reservation_id) pm.collectionVariables.set('reservationId', json.result.reservation_id);"
                ]
              }
            }
          ],
