    {
      "name": "02 - Courier Wallet / Soporte operativo",
      "description": "Endpoints de wallet utiles para revisar deuda por efectivo y liquidarla. Normalmente los consume app de courier/admin, no Restaurante directamente.",
      "item": [
        {
          "name": "GET /api/wallet/summary - resumen de courier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('wallet summary valido', () => {",
                  "  pm.expect(json.ok).to.eql(true);",
                  "  pm.expect(json.result).to.include.keys('balances', 'morosityState', 'transactions');",
                  "});",
                  "const pendingCash = json.result.transactions.find(t => t.paymentMethod === 'CASH' && t.isDebtSettled === false);",
                  "if (pendingCash?.transactionId) pm.collectionVariables.set('cashDebtTransactionId', pendingCash.transactionId);",
                  "if (pendingCash?.orderId) pm.collectionVariables.set('cashDebtOrderId', pendingCash.orderId);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "description": "Consulta balances y transacciones del courier. Requiere courierId. Puede filtrarse con startDate y endDate en formato YYYY-MM-DD.",
            "url": {
              "raw": "{{baseUrl}}/api/wallet/summary?courierId={{courierId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "summary"],
              "query": [{ "key": "courierId", "value": "{{courierId}}" }]
            }
          },
          "response": []
        },
        {
